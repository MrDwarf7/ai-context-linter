    "cursorrules",
    "agents-md"
  ],
  "author": "MrDwarf7",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/glob": "^0.4.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MrDwarf7/ai-context-linter"
  }
