  "description": "Lint and validate AI coding context files (CLAUDE.md, .cursorrules, AGENTS.md) against best practices.",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.js -o dist",
    "test": "node --test __tests__/*.test.js",
    "lint": "node src/index.js"
  },
  "keywords": [
    "github-action",
    "ai",
    "claude",
    "cursor",
    "copilot",
    "context",
    "linter",
